<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Domain\Model\Order" repository-class="Infrastructure\Doctrine\Repository\OrderRepository" table="purchase_order">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>
        <field name="reference" type="string" length="20" unique="true" />
        <field name="createdAt" type="datetime_immutable" />
        <field name="status" type="string" length="50" /> <field name="totalPrice" type="integer" />

        <many-to-one field="user" target-entity="Domain\Model\User" inversed-by="orders">
            <join-column name="user_id" referenced-column-name="id" nullable="false" />
        </many-to-one>

        <one-to-many field="items" target-entity="Domain\Model\OrderItem" mapped-by="order" orphan-removal="true">
            <cascade><cascade-all/></cascade>
        </one-to-many>
    </entity>
</doctrine-mapping>