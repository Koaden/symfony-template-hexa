<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Domain\Model\User" repository-class="Infrastructure\Doctrine\Repository\UserRepository" table="app_user">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>
        <field name="email" column="email" type="string" length="180" unique="true" />
        <field name="roles" column="roles" type="json" />
        <field name="password" column="password" type="string" />
        <one-to-many field="orders" target-entity="Domain\Model\Order" mapped-by="user" />
    </entity>
</doctrine-mapping>