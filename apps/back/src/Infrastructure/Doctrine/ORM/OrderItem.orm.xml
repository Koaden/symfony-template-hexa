<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="Domain\Model\OrderItem" table="order_item">
        <id name="id" type="integer" column="id">
            <generator strategy="AUTO"/>
        </id>
        <field name="quantity" type="integer" />
        <field name="unitPrice" type="integer" />

        <many-to-one field="order" target-entity="Domain\Model\Order" inversed-by="items">
            <join-column name="order_id" referenced-column-name="id" nullable="false" on-delete="CASCADE" />
        </many-to-one>

        <many-to-one field="product" target-entity="Domain\Model\Product">
            <join-column name="product_id" referenced-column-name="id" on-delete="RESTRICT" />
        </many-to-one>
    </entity>
</doctrine-mapping>